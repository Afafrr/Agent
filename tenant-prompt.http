@vapiTimestamp = 1775993358713
@vapiSignature = f5df6fb60bdfc33ad2725b49c6c052850a0289b58cab2bfcbd4a1758a4196dd8

### Get tenant prompt config (Vapi tool-calls format)
GET {{baseUrl}}/tenant/prompt
Content-Type: application/json
x-timestamp: {{vapiTimestamp}}
x-signature: {{vapiSignature}}

###

### Get tenant prompt config — SIP header fallback
GET {{baseUrl}}/tenant/prompt
Content-Type: application/json
x-timestamp: {{vapiTimestamp}}
x-signature: {{vapiSignature}}

{
  "message": {
    "type": "tool-calls",
    "call": {
      "transport": {
        "sip": {
          "headers": {
            "X-telnyx-call-control-id": "CALL_CONTROL_ID"
          }
        }
      }
    },
    "toolCallList": [
      {
        "id": "tool-call-1",
        "type": "function",
        "function": {
          "name": "get_prompt_config",
          "arguments": "{}"
        }
      }
    ]
  }
}
